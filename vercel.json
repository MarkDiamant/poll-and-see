{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [

    {
      "path": "/api/digest?secret=@DIGEST_SECRET",
      "schedule": "30 12 * 11,12 0-5"
    },

    {
      "path": "/api/digest?secret=@DIGEST_SECRET",
      "schedule": "30 12 * 1-3 0-5"
    },

    {
      "path": "/api/digest?secret=@DIGEST_SECRET",
      "schedule": "30 11 * 4-10 0-5"
    }

  ]
}